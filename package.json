{
  "name": "@fin-folio/root",
  "version": "1.0.0",
  "private": true,
  "description": "Fin Folio - Personal Finance Management (monorepo)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prepare": "husky",
    "infra:start": "node scripts/setup.mjs infra:start",
    "infra:stop": "node scripts/setup.mjs infra:stop",
    "env:copy": "node scripts/setup.mjs env:copy",
    "db:generate": "node scripts/setup.mjs db:generate",
    "db:migrate": "node scripts/setup.mjs db:migrate",
    "setup": "node scripts/setup.mjs"
  },
  "author": "Himanshu",
  "license": "ISC",
  "keywords": [],
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@fin-folio/eslint-config": "workspace:*",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
