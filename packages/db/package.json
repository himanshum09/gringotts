{
  "name": "@fin-folio/db",
  "version": "0.0.0",
  "private": true,
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "default": "./dist/nestjs/index.js"
    }
  },
  "scripts": {
    "db:generate": "pnpm build && drizzle-kit generate",
    "db:migrate": "pnpm build && drizzle-kit migrate",
    "db:push": "pnpm build && drizzle-kit push",
    "db:studio": "pnpm build && drizzle-kit studio",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "pg": "^8.13.0",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@fin-folio/eslint-config": "workspace:*",
    "@fin-folio/tsconfig": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": ">=11.0.0",
    "@nestjs/core": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  }
}
